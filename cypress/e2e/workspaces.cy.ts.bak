describe('Workspaces Page', () => {
  beforeEach(() => {
    cy.visit('http://localhost:8002/workspaces');
    // Wait for the SPA to load
    cy.get('#app-mount', { timeout: 10000 }).should('not.be.empty');
  });

  it('should load the workspaces page successfully', () => {
    cy.url().should('include', '/workspaces');
  });

  it('should display the page title', () => {
    cy.get('h1').should('be.visible');
  });

  it('should find and click the default link', () => {
    // Find the first visible link and click it
    cy.get('a').should('be.visible').first().as('defaultLink');
    
    cy.get('@defaultLink').then(($link) => {
      const linkText = $link.text().trim();
      cy.log(`Clicking link: "${linkText}"`);
      cy.wrap($link).click();
    });

    // Wait for navigation
    cy.wait(1000);
  });

  it('should click the first workspace link if available', () => {
    // Try to find a workspace-related link
    cy.get('body').then(($body) => {
      // Check if there's a link containing "workspace" (case-insensitive)
      if ($body.find('a:contains("workspace"), a:contains("Workspace")').length > 0) {
        cy.contains('a', /workspace/i).first().click();
      } else {
        // Otherwise click the first link found
        cy.get('a').first().click();
      }
    });
  });

  it('should have no console errors', () => {
    cy.window().then((win) => {
      cy.spy(win.console, 'error').as('consoleError');
    });
    cy.get('@consoleError').should('not.have.been.called');
  });
});
